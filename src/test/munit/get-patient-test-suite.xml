<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="get-patient-test-suite.xml" />
	<munit:test name="sub-get-patient-by-doctorTest" doc:id="6f0426d8-07f1-4239-a212-69f4c30f0bb9" description="Test">
		<munit:behavior >
			<munit-tools:mock-when doc:name="database-system-api:retrieve-patient" doc:id="f63ec15d-5300-45ed-b844-cca605085d4d" processor="database-system-api:retrieve-patient">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="sys-database : Retrieve [patient]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="9c491215-8a67-4a6a-8168-865df1671511" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="patient" value='#[readUrl("classpath://data/patient.json", "application/json")]' />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="database-system-api:retrieve-medical-record" doc:id="2cec22f4-04d7-4191-88e3-7e2545528c9a" processor="database-system-api:retrieve-medical-record">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="sys-database : Retrieve [medicalRecord]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="8a28c502-4ea4-4f36-bfa2-3fbfeb5fbefb" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="medicalRecord" value='#[readUrl("classpath://data/medicalRecord.json", "application/json")]' />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="sftp-system-api:retrieve-laboratory-results" doc:id="364b6538-eacc-4de0-95a9-a278c6cf57eb" processor="sftp-system-api:retrieve-results_1">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="sys-sftp : Retrieve [laboratoryResults]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="0705fe6f-88ab-4c8c-a54c-a84c6c599899" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="laboratoryResults" value='#[readUrl("classpath://data/laboratoryResults.json", "application/json")]' />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="sftp-system-api:retrieve-radiology-results" doc:id="73c87523-3322-4849-8cef-dfe33b4d21ea" processor="sftp-system-api:retrieve-results_2">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="sys-sftp : Retrieve [radiologyResults]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="6591682d-49c2-4e47-a21b-b04671b485a2" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="radiologyResults" value='#[readUrl("classpath://data/radiologyResults.json", "application/json")]' />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<set-variable value="FAC-10001" doc:name="[patientId]" doc:id="46220182-1aff-4b37-92ef-5040bd9df536" variableName="patientId" />
			<set-variable value="doctor" doc:name="[role]" doc:id="496da5f3-5721-4abf-8ef9-9a5d0eedd050" variableName="role" />
			<flow-ref doc:name="Flow-ref to sub-get-patient" doc:id="a73ae03e-7886-4641-95e4-7115f39d8f2f" name="sub-get-patient"/>
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-equals doc:name="Payload should contain patient data model" doc:id="e075f7ae-3bbd-4c14-813e-003b20e1207b" actual="#[payload]" expected='#[readUrl("classpath://data/patientDataModel.json", "application/json")]' message="Payload should contain patient data model"/>
		</munit:validation>
	</munit:test>
	<munit:test name="sub-patient-not-foundTest" doc:id="573c60b7-738c-4520-84f0-67dbc77ae8a0" description="Test">
		<munit:behavior>
			<munit-tools:mock-when doc:name="database-system-api:retrieve-patient" doc:id="812c2015-8865-4c18-91bb-29cd3132774d" processor="database-system-api:retrieve-patient" >
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="sys-database : Retrieve [patient]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="9c491215-8a67-4a6a-8168-865df1671511" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:error typeId="PATIENT:NOT_FOUND" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<set-variable value="FAC-11111" doc:name="[patientId]" doc:id="7dab2fb6-f4a6-4456-a078-3d9a07a6d1fd" variableName="patientId" />
			<set-variable value="doctor" doc:name="[role]" doc:id="0ded95de-6953-4700-b33d-76d2ce548976" variableName="role" />
			<set-variable value="sub-get-patient" doc:name="[testedFlow]" doc:id="e0e27e62-76f0-415e-977c-dac2ad9cd827" variableName="testedFlow" />
			<try doc:name="Try" doc:id="c5440237-dba4-4426-a28f-b0095980bb21" >
				<flow-ref doc:name="apikit-mock" doc:id="2a71bd5c-5ad2-4442-95ed-a66306e9c383" name="apikit-mock" />
				<error-handler >
					<on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="a9421447-f354-4011-a308-f46145b0c674" type="PATIENT:NOT_FOUND" />
				</error-handler>
			</try>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-equals doc:name="HTTP Status" doc:id="577df152-1a34-4ffd-9998-baed666909a8" actual="#[vars.httpStatus]" expected='#[404 as Number]' />
			<munit-tools:verify-call doc:name="Last error logger" doc:id="baa2ab1b-d143-4358-aa98-60b01c74401e" processor="logger" times="1" >
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="ERROR" attributeName="level" />
					<munit-tools:with-attribute whereValue="ERROR" attributeName="doc:name" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
		</munit:validation>
	</munit:test>


</mule>
