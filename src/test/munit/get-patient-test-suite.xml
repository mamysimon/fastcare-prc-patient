					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="sftp-system-api:retrieve-results_" doc:id="8dd4aafe-971f-4dfd-9441-291efb619544" processor="sftp-system-api:retrieve-results_1" >
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Retrieve [laboratoryResults]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="0705fe6f-88ab-4c8c-a54c-a84c6c599899" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="laboratoryResults" value='#[readUrl("classpath://data/laboratoryResults.json", "application/json")]' />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="sftp-system-api:retrieve-results_1" doc:id="f30a66bd-9ae2-4073-9f9a-51a57a09d3e8" processor="sftp-system-api:retrieve-results_2" >
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Retrieve [radiologyResults]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="6591682d-49c2-4e47-a21b-b04671b485a2" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="radiologyResults" value='#[readUrl("classpath://data/radiologyResults.json", "application/json")]' />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:spy doc:name="Transform message filter" doc:id="c2d01bb0-635d-4269-85bb-2d804973ebe6" processor="ee:transform">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Filter [patientDataModelFiltered] by role" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="e066c27d-ca91-4fd3-b5be-2cfde51fe452" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:before-call>
					<munit-tools:assert-equals doc:name="Variabla patientDataModel should contain entire patient data model" doc:id="eb7af629-4485-42ce-b0e9-c573d7663254" actual="#[vars.patientDataModel]" expected='#[readUrl("classpath://data/patientDataModelForDoctor.json", "application/json")]' message="Variabla patientDataModel should contain entire patient data model"/>
				</munit-tools:before-call>
				<munit-tools:after-call>
					<munit-tools:assert-that doc:name="Variable patientDataModelFiltered exists" doc:id="488c45fb-1790-434e-af4a-81a07e47ccd9" expression="#[vars.patientDataModelFiltered != null]" is="#[MunitTools::notNullValue()]"/>
				</munit-tools:after-call>
			</munit-tools:spy>
		</munit:behavior>
		<munit:execution >
			<set-variable value="FAC-10001" doc:name="[patientId]" doc:id="259c54c4-1a68-4a56-ac1b-ea807a94f50a" variableName="patientId" />
			<set-variable value="patient" doc:name="[role]" doc:id="1f39240f-47a3-4556-94ce-0ff5494948e4" variableName="role" />
			<flow-ref doc:name="Flow-ref to sub-get-patient" doc:id="07133403-f66f-4381-bc6d-66c27e3b9612" name="sub-get-patient" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-equals doc:name="Payload should contain filtered patient data model for patient" doc:id="46c48c35-9fbc-4fda-a692-31d9b1997fbc" actual="#[payload]" expected='#[readUrl("classpath://data/patientDataModelForPatient.json", "application/json")]' message="Payload should contain filtered patient data model for patient"/>
		</munit:validation>
	</munit:test>
	<munit:test name="sub-patient-not-foundTest" doc:id="573c60b7-738c-4520-84f0-67dbc77ae8a0" description="Test" expectedErrorType="ANY">
		<munit:behavior>
			<munit-tools:mock-when doc:name="database-system-api:retrieve-patient" doc:id="812c2015-8865-4c18-91bb-29cd3132774d" processor="database-system-api:retrieve-patient" >
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Retrieve [patient]" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="a599ec0b-b747-4584-a6ef-20c3427063d4" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:error typeId="PATIENT:NOT_FOUND" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<set-variable value="FAC-11111" doc:name="[patientId]" doc:id="7dab2fb6-f4a6-4456-a078-3d9a07a6d1fd" variableName="patientId" />
			<set-variable value="doctor" doc:name="[role]" doc:id="0ded95de-6953-4700-b33d-76d2ce548976" variableName="role" />
			<flow-ref doc:name="Flow-ref to sub-get-patient" doc:id="2a71bd5c-5ad2-4442-95ed-a66306e9c383" name="sub-get-patient" />
		</munit:execution>
	</munit:test>


</mule>
